rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Felhasználói profil – olvasás: bármelyik bejelentkezett (kereséshez, barát megjelenítéshez), írás: csak saját
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Havi statisztika alkollekció
      match /stats/{statsId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Barátság – csak az érintett két fél kezelhet
    match /friendships/{friendshipId} {
      // get: egyedi doc olvasás (pl. létezés ellenőrzés) – resource lehet null, ezért külön
      allow get: if request.auth != null;
      // list: lekérdezésnél csak saját barátságok jelennek meg
      allow list: if request.auth != null &&
        (resource.data.user1 == request.auth.uid || resource.data.user2 == request.auth.uid);
      allow create: if request.auth != null &&
        request.resource.data.requesterId == request.auth.uid &&
        (request.resource.data.user1 == request.auth.uid || request.resource.data.user2 == request.auth.uid);
      allow update: if request.auth != null &&
        (resource.data.user1 == request.auth.uid || resource.data.user2 == request.auth.uid);
      allow delete: if request.auth != null &&
        (resource.data.user1 == request.auth.uid || resource.data.user2 == request.auth.uid);
    }

    // Tevékenységek – csak saját tevékenységeket kezelhet
    match /activities/{activityId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Közösségi termékadatbázis – mindenki olvashatja, bejelentkezett írhatja
    match /community_products/{barcode} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
