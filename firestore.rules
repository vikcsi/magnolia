rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Megvizsgálja, hogy a két felhasználó elfogadott barátok-e
    function areFriends(uid1, uid2) {
      let fid = uid1 < uid2 ? uid1 + '_' + uid2 : uid2 + '_' + uid1;
      return exists(/databases/$(database)/documents/friendships/$(fid)) &&
             get(/databases/$(database)/documents/friendships/$(fid)).data.status == 'accepted';
    }

    // Felhasználói profil – olvasás: bármelyik bejelentkezett (leaderboard, compare), írás: csak saját
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isOwner(userId);
      match /stats/{statsId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Barátság – csak az érintett két fél kezelhet
    match /friendships/{friendshipId} {
      allow get: if isAuth();
      allow list: if isAuth() &&
        (resource.data.user1 == request.auth.uid || resource.data.user2 == request.auth.uid);
      allow create: if isAuth() &&
        request.resource.data.requesterId == request.auth.uid &&
        (request.resource.data.user1 == request.auth.uid || request.resource.data.user2 == request.auth.uid);
      allow update: if isAuth() &&
        (resource.data.user1 == request.auth.uid || resource.data.user2 == request.auth.uid);
      allow delete: if isAuth() &&
        (resource.data.user1 == request.auth.uid || resource.data.user2 == request.auth.uid);
    }

    // Tevékenységek – olvasás: saját, vagy elfogadott barát (összehasonlítás streak-hez)
    match /activities/{activityId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        areFriends(request.auth.uid, resource.data.userId)
      );
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // Közösségi termékadatbázis
    match /community_products/{barcode} {
      allow read: if true;
      allow write: if isAuth();
    }

    // Globális kihívások – bármelyik bejelentkezett olvashatja
    match /global_challenges/{challengeId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Felhasználói kihívások – saját, vagy elfogadott barát olvashatja (összehasonlítás)
    match /user_challenges/{challengeId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        areFriends(request.auth.uid, resource.data.userId)
      );
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // Felhasználói célok – saját, vagy elfogadott barát olvashatja (összehasonlítás)
    match /user_goals/{goalId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        areFriends(request.auth.uid, resource.data.userId)
      );
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
    }
  }
}
